    {
      "parameters": {
        "jsCode": "// Take the AI Agent output\nconst text = $json[\"output\"]; // use the actual field name\n\n// Extract SUBJECT\nconst subjectMatch = text.match(/SUBJECT:\\s*(.*)/);\n\n// Extract EMAIL BODY\nconst bodyMatch = text.match(/EMAIL BODY:\\s*([\\s\\S]*?)\\nACTION:/);\n\n// Extract ACTION\nconst actionMatch = text.match(/ACTION:\\s*(.*)/);\n\nreturn [{\n  json: {\n    response_subject: subjectMatch ? subjectMatch[1].trim() : \"\",\n    response_body: bodyMatch ? bodyMatch[1].trim() : \"\",\n    response_action: actionMatch ? actionMatch[1].trim() : \"\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        -176
      ],
      "id": "f5952363-834a-4953-b392-1be90f5ff4d1",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Initialize body\nlet bodyData = '';\n\n// Check for multipart text/plain\nif ($json.payload && $json.payload.parts && $json.payload.parts.length > 0) {\n    const textPart = $json.payload.parts.find(p => p.mimeType === 'text/plain');\n    if (textPart && textPart.body && textPart.body.data) {\n        bodyData = Buffer.from(textPart.body.data, 'base64').toString('utf-8');\n    }\n}\n\n// Check for single body\nelse if ($json.payload && $json.payload.body && $json.payload.body.data) {\n    bodyData = Buffer.from($json.payload.body.data, 'base64').toString('utf-8');\n}\n\n// Fallback: use snippet if nothing else\nif (!bodyData && $json.snippet) {\n    bodyData = $json.snippet;\n}\n\n// Return clean JSON\nreturn [\n  {\n    json: {\n      From: $json.From,\n      Subject: $json.Subject,\n      Body: bodyData\n    }\n  }\n];"
      },
