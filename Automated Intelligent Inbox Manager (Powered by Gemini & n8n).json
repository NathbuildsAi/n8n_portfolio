    {
      "parameters": {
        "jsCode": "// --------------------------------------------------\n// Important Senders Configuration\n// --------------------------------------------------\n// Add email addresses that should trigger the AI\n// auto-reply workflow.\n//\n// Replace these example emails with real ones\n// when using the workflow yourself.\n// --------------------------------------------------\n\nconst importantSenders = [\n  \"vip@example.com\",\n  \"client@example.com\",\n  \"boss@example.org\"\n];\n\n// Normalize emails (lowercase + remove spaces)\nconst senderList = importantSenders\n  .map(email => email.trim().toLowerCase())\n  .filter(email => email !== \"\");\n\n// Output configuration\nreturn [\n  {\n    json: {\n      senderList: senderList,\n      count: senderList.length,\n      description: \"List of important senders used by the workflow\"\n    }\n  }\n];"
      },
      "id": "4b731177-4f70-480a-acc8-1e9a5dd8530d",
      "name": "Important Senders Config",
      "type": "n8n-nodes-base.code",
