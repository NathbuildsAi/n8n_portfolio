    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// AI Agent failed — skip reply\nif (input.error) {\n  return [{\n    json: {\n      response_subject: \"\",\n      response_body: \"\",\n      response_action: \"No response needed\",\n      error: input.error.message || \"AI agent failed\"\n    }\n  }];\n}\n\nconst text = input.output || '';\n\nconst subjectMatch = text.match(/SUBJECT:\\s*(.*)/);\nconst bodyMatch = text.match(/EMAIL BODY:\\s*([\\s\\S]*?)\\nACTION:/);\nconst actionMatch = text.match(/ACTION:\\s*(.*)/);\n\nreturn [{\n  json: {\n    response_subject: subjectMatch ? subjectMatch[1].trim() : \"\",\n    response_body: bodyMatch ? bodyMatch[1].trim() : \"\",\n    response_action: actionMatch ? actionMatch[1].trim() : \"No response needed\"\n  }\n}];"
      },
