    {
      "parameters": {
        "jsCode": "const importantSenders = [\n\"vip@example.com\",\n\"client@example.com\"\n];\n\nconst senderList = importantSenders.map(s => s.toLowerCase());\n\nreturn [{\njson: {\nsenderList: senderList,\ncount: senderList.length\n}\n}];"
      },
      "id": "e505be47-2c8f-455c-89c5-657aa73c21a7",
      "name": "Important Senders Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-128, -80]
    },
    {
      "parameters": {
        "jsCode": "const gmailData = $node[\"Gmail Trigger\"].json;\nconst sender = gmailData.From || gmailData.from;\n\nif (!sender) {\nreturn {\njson: {\nisImportant: false,\nstatus: \"Error: Could not find email data from the Gmail Trigger.\"\n}\n};\n}\n\nconst configData = $node[\"Important Senders Config\"].json;\nconst senderList = configData.senderList || [];\n\nconst fromEmail = sender.toLowerCase();\nconst isImportant = senderList.some(s => fromEmail.includes(s.toLowerCase()));\n\nreturn {\njson: {\n...gmailData,\nisImportant: isImportant,\nmatchedSender: isImportant ? fromEmail : null\n}\n};"
      },
      "id": "a419afa7-0a87-4638-a219-30164468fddd",
      "name": "Check Sender Match",
      "type": "n8n-nodes-base.code",
