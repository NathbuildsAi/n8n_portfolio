    {
      "parameters": {
        "jsCode": "let bodyData = '';\n\nif ($json.payload && $json.payload.parts && $json.payload.parts.length > 0) {\n    const textPart = $json.payload.parts.find(p => p.mimeType === 'text/plain');\n    if (textPart && textPart.body && textPart.body.data) {\n        bodyData = Buffer.from(textPart.body.data, 'base64').toString('utf-8');\n    }\n}\n\nelse if ($json.payload && $json.payload.body && $json.payload.body.data) {\n    bodyData = Buffer.from($json.payload.body.data, 'base64').toString('utf-8');\n}\n\nif (!bodyData && $json.snippet) {\n    bodyData = $json.snippet;\n}\n\nreturn [\n  {\n    json: {\n      From: $json.From,\n      Subject: $json.Subject,\n      Body: bodyData\n    }\n  }\n];"
      },
