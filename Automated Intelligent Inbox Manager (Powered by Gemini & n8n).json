        -80
      ]
    },
    {
      "parameters": {
        "jsCode": "// 1. Specifically pull the \"From\" field from the Gmail Trigger node\nconst gmailData = $node[\"Gmail Trigger\"].json;\nconst sender = gmailData.From || gmailData.from;\n\nif (!sender) {\nreturn {\njson: {\nisImportant: false,\nstatus: \"Error: Could not find email data from the Gmail Trigger.\"\n}\n};\n}\n\n// 2. Get your VIP list from the Config node\nconst configData = $node[\"Important Senders Config\"].json;\nconst senderList = configData.senderList || [];\n\n// 3. Compare them\nconst fromEmail = sender.toLowerCase();\nconst isImportant = senderList.some(s => fromEmail.includes(s.toLowerCase()));\n\nreturn {\njson: {\n...gmailData,\nisImportant: isImportant,\nmatchedSender: isImportant ? fromEmail : null\n}\n};"
      },
